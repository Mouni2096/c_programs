//palindrome number

#include <stdio.h>

int main()
{
 int n,rev,rem,org;
 rev=0;
 scanf("%d",&n);
 org = n;
 while(n!=0){
     rem=n%10;
     rev=rev*10 + rem;
     n=n/10;
 }
     if(org==rev){
         printf("palindrome number");
     }else{
         printf("Not a palindrome number");
     }
 
    return 0;
}


//factorial of a number

#include <stdio.h>
int factorial(int n){
    if(n==1){
    return 1;}
    else{
        return(n*factorial(n-1));
    }
}
int main()

{

   printf("factorial:%d",factorial(5));
}
