//Macros to find maximum of two numbers
#include<stdio.h>
#define MAX(a,b) ((a>b)?(a):(b))
int main(){
    int a,b;
    scanf("%d",&a);
  scanf("%d",&b);
        printf("The greater number is:%d\n",MAX(a,b));
return 0;
}


//Macros to find minimum of two numbers
