//To find a word and the number of times it occurs in a file
#include<stdio.h>
#include<string.h>
int main(){
FILE *m;
char n[30],o[50];
int p=0;
m = fopen("mouni.txt","r");
scanf("%s",&n);
while(fscanf(m,"%s",o)!= EOF){
    if(strcmp(n,o)==0){
        p++;
}}
printf("%s occurs %d time`",n,p);
fclose(m);
return 0;
}

//to merge files
#include<stdio.h>
#include<string.h>
int main(){
    FILE *m, *n, *o;
char p,q,r;
m = fopen("employee details.txt","r");
n = fopen("student details.txt","r");
o = fopen("append.txt","w");

while((p=fgetc(m)) != EOF){
    fputc(p,o);
}

while((q=fgetc(n)) != EOF){
    fputc(q,o);
}

    fclose(m);
    fclose(n);
    fclose(o);

    return 0;}


//to find average of marks:
#include<stdio.h>
    #include<string.h>
    struct student{
    int rollno;
    int mark;
    }n1,n2;

    void read(){
        FILE *m;
    m=fopen("student.txt","w");
    scanf("%d",&n1.rollno);
    scanf("%d",&n1.mark);
    printf("The roll no is:%d\n",n1.rollno);
    printf("The mark is:%d\n",n1.mark);
    scanf("%d",&n2.rollno);
    scanf("%d",&n2.mark);
    printf("The roll no is:%d\n",n2.rollno);
    printf("The mark is:%d\n",n2.mark);
    fprintf(m,"The roll no of n1 is:%d\n The mark of n1 is:%d\nThe roll no of n2 is:%d\n The mark of n2 is:%d\n",n1.rollno,n1.mark,n2.rollno,n2.mark);
    }
    void write(){
    FILE *m;
    m = fopen("student.txt","r");
    while(fscanf(m,"%d%d%d%d",&n1.rollno,&n1.mark,&n2.rollno,&n2.mark) != EOF){
    fprintf(m,"The roll no of n1 is:%d\n The mark of n1 is:%d\nThe roll no of n2 is:%d\n The mark of n2 is:%d\n",n1.rollno,n1.mark,n2.rollno,n2.mark);
    }fclose(m);
    }

    void average(){
    FILE *m;
    int sum=0;
    float average=0;
    fopen("student.txt","r");
    while(fscanf(m,"%d%d%d%d",&n1.rollno,&n1.mark,&n2.rollno,&n2.mark) != EOF){
        sum = n1.mark + n2.mark;
    }
    average = sum/2;
    printf("average:%f",average);
    }
    int main(){
    read();
    write();
    average();
    return 0;
    }





