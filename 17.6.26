#include<stdio.h>
#include<string.h>
FILE*m;
int main(){
char n;
m=fopen("student details.txt","r");
while((n = fgetc(m)) != EOF){
printf("%c",n);
}
fclose(m);
return 0;
}


//To find count of characters,words,lines
#include<stdio.h>
int main(){
FILE*m;
char ch;
int n=0,w=0,s =0;
m=fopen("mouni.txt","r");
while((ch=fgetc(m)) != EOF){
    n++;
    if(ch==' ' || ch=='\n')
        w++;
    if(ch=='\n')
        s++;
}
if(n>0)
    w++;
    printf("The number of characters are:%d\n",n);
    printf("The number of words are:%d\n",w);
    printf("The number of lines are:%d\n",s);
    fclose(m);
    return 0;
}


//copy contents of one file to another
#include<stdio.h>
int main(){
    FILE*c,*d;
    char e;
c=fopen("mouni.txt","r");
d=fopen("create.txt","w");
while((e=getc(c)) != EOF)
fputc(e,d);
fclose(c);
fclose(d);
return 0;
}


